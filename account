  top: 7px;
  left: 8px;
  color: rgba(255, 255, 255, 0.32);
  font-size: 13px;
  font-weight: 900;
}

.bay-wash-timer {
  position: absolute;
  z-index: 4;
  top: 6px;
  right: 5px;
  min-width: 52px;
  padding: 3px 5px;
  border: 1px solid rgba(255, 229, 137, 0.38);
  border-radius: 6px;
  background: rgba(13, 23, 20, 0.78);
  color: #ffe589;
  font-size: 9px;
  font-variant-numeric: tabular-nums;
  font-weight: 900;
  line-height: 1;
  text-align: center;
}

.bay-map-empty-mark {
  display: grid;
  place-items: center;
  width: 46px;
  height: 64px;
  border: 2px dashed rgba(255, 255, 255, 0.2);
  border-radius: 8px;
  color: rgba(255, 255, 255, 0.2);
  font-size: 24px;
  font-weight: 900;
  animation: bay-empty-pulse 3.6s ease-in-out infinite;
}

.bay-map-car {
  position: relative;
  z-index: 2;
  width: min(58%, 64px);
  height: auto;
  overflow: visible;
  filter: drop-shadow(0 9px 8px rgba(0, 0, 0, 0.32));
  animation: bay-car-arrive 650ms cubic-bezier(0.2, 0.85, 0.3, 1) both, bay-car-idle 3.2s ease-in-out 700ms infinite;
}

.bay-car-shadow {
  fill: rgba(0, 0, 0, 0.28);
}

.bay-car-wheel {
  fill: #111715;
}

.bay-car-body {
  fill: var(--bay-car-color);
  stroke: rgba(255, 255, 255, 0.34);
  stroke-width: 1.5;
}

.car-color-0 { --bay-car-color: #168d83; }
.car-color-1 { --bay-car-color: #e0a92e; }
.car-color-2 { --bay-car-color: #3d73b9; }
.car-color-3 { --bay-car-color: #d35e52; }
.car-color-4 { --bay-car-color: #56a765; }
.car-color-5 { --bay-car-color: #727b82; }

.bay-car-glass {
  fill: #173b43;
  stroke: rgba(175, 231, 235, 0.52);
  stroke-width: 1;
}

.bay-car-roof {
  fill: color-mix(in srgb, var(--bay-car-color) 82%, #ffffff);
}

.bay-car-highlight {
  fill: rgba(255, 255, 255, 0.18);
}

.bay-car-light {
  fill: #fff2a8;
}

.bay-car-tail {
  fill: #ff6b5f;
}

.bay-wash-sweep {
  position: absolute;
  z-index: 3;
  top: -35%;
  width: 150%;
  height: 30%;
  transform: rotate(-9deg);
  background: linear-gradient(180deg, transparent, rgba(133, 231, 239, 0.58), transparent);
  filter: blur(2px);
  pointer-events: none;
  animation: bay-wash-sweep 2.8s ease-in-out infinite;
}

@keyframes bay-car-arrive {
  from {
    opacity: 0;
    transform: translateY(115%) scale(0.9);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes bay-car-idle {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-2px);
  }
}

@keyframes bay-wash-sweep {
  0%,
  12% {
    top: -35%;
    opacity: 0;
  }
  28% {
    opacity: 0.85;
  }
  76% {
    opacity: 0.7;
  }
  92%,
  100% {
    top: 105%;
    opacity: 0;
  }
}

@keyframes bay-empty-pulse {
  0%,
  100% {
    border-color: rgba(255, 255, 255, 0.16);
    color: rgba(255, 255, 255, 0.16);
  }
  50% {
    border-color: rgba(137, 220, 205, 0.36);
    color: rgba(137, 220, 205, 0.32);
  }
}

