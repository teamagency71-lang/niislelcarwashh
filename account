  color: #acbab5;
  font-size: 9px;
  line-height: 1.3;
}

.bay-map-lane {
  position: relative;
  display: grid;
  place-items: center;
  min-width: 0;
  overflow: hidden;
  border-top: 2px solid rgba(255, 255, 255, 0.82);
  border-right: 2px solid rgba(255, 255, 255, 0.82);
  border-left: 2px solid rgba(255, 255, 255, 0.82);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.025), rgba(0, 0, 0, 0.08));
}

.bay-map-lane::after {
  position: absolute;
  right: 10%;
  bottom: 6px;
  left: 10%;
  height: 3px;
  border-radius: 2px;
  background: #f0c84a;
  content: "";
}

.bay-map-number {
