  margin: -4px 0 0;
  color: var(--muted);
  font-size: 11px;
  font-weight: 800;
}

.director-lock-feedback.error {
  color: var(--red);
}

.director-lock-feedback.success {
  color: var(--green);
}

.director-protected-content {
  display: grid;
  gap: 11px;
}

.director-range-tabs {
  margin-bottom: 0;
}

