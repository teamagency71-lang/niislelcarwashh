.panel-header.compact {
  margin-bottom: 12px;
}

.panel-header.compact h3 {
  margin: 0;
  font-size: 16px;
}

.finance-bars {
  display: grid;
  gap: 12px;
  padding: 16px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: #fafbf8;
}

.finance-bars-chart {
  display: flex;
  align-items: end;
  gap: 10px;
  min-height: 160px;
}

.finance-donut-layout {
  display: grid;
  grid-template-columns: 210px minmax(0, 1fr);
  align-items: center;
  gap: 20px;
}

.finance-donut {
  position: relative;
  display: grid;
  place-items: center;
  width: 210px;
  aspect-ratio: 1;
  border-radius: 50%;
