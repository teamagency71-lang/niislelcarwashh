  font-size: 16px;
}

.director-shift-archive-list {
  display: grid;
  gap: 8px;
}

.director-shift-archive-row {
  display: grid;
  gap: 9px;
  padding: 11px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--surface);
}

.director-shift-archive-title strong {
  font-size: 13px;
}

.director-shift-archive-title span {
  color: var(--muted);
  font-size: 11px;
  font-weight: 800;
  text-align: right;
}

.director-shift-archive-summary {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 6px;
}

.director-shift-archive-summary span {
  display: grid;
  gap: 3px;
  min-width: 0;
  padding: 7px;
  border-radius: 7px;
  background: var(--surface-soft);
  color: var(--muted);
  font-size: 10px;
  font-weight: 800;
}

.director-shift-archive-summary strong {
  overflow-wrap: anywhere;
  color: var(--ink);
  font-size: 12px;
}

.director-shift-payment-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.director-shift-payment-summary small {
  padding: 5px 7px;
  border: 1px solid var(--line);
  border-radius: 7px;
  color: var(--muted);
  font-size: 10px;
  font-weight: 800;
}

.director-shift-note {
  margin: 0;
  padding: 8px 9px;
  border-left: 3px solid var(--amber);
  border-radius: 0 7px 7px 0;
  background: var(--surface-soft);
  color: var(--muted);
  font-size: 11px;
  line-height: 1.45;
  overflow-wrap: anywhere;
}

.director-shift-note strong {
  color: var(--ink);
}

.director-shift-archive-empty {
  margin: 0;
  padding: 14px;
  border: 1px dashed var(--line);
  border-radius: 8px;
  color: var(--muted);
  text-align: center;
  font-size: 12px;
  font-weight: 800;
}

@media (max-width: 760px) {
  .director-shift-archive-title {
    align-items: flex-start;
    flex-direction: column;
    gap: 4px;
  }

  .director-shift-archive-title span {
    text-align: left;
  }

  .director-shift-archive-summary {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

.visually-hidden {
  position: absolute !important;
  width: 1px !important;
  height: 1px !important;
  overflow: hidden !important;
  clip: rect(0 0 0 0) !important;
  white-space: nowrap !important;
  clip-path: inset(50%) !important;
}

.director-module {
  overflow: hidden;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--surface);
}

.director-module > .director-module-summary {
  display: flex;
  align-items: center;
  gap: 10px;
  min-height: 58px;
  padding: 10px 12px;
  border: 0;
  border-radius: 0;
  background: var(--surface);
  color: var(--ink);
  cursor: pointer;
  list-style: none;
}

.director-module > .director-module-summary::-webkit-details-marker {
  display: none;
}

.director-module-emblem {
  display: grid;
  flex: 0 0 36px;
  place-items: center;
  width: 36px;
  height: 36px;
  border: 1px solid rgba(15, 124, 99, 0.2);
  border-radius: 50%;
  background: rgba(15, 124, 99, 0.1);
  color: var(--teal-dark);
}

.director-module-emblem svg {
  width: 19px;
  height: 19px;
}

.director-module-copy {
  display: grid;
  flex: 1 1 auto;
  gap: 2px;
  min-width: 0;
}

.director-module-copy strong {
  overflow: hidden;
  font-size: 14px;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.director-module-copy small {
  overflow: hidden;
  color: var(--muted);
  font-size: 10px;
  font-weight: 750;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.director-module-summary > .pill {
  flex: 0 0 auto;
}

.director-module-chevron,
.director-module .mobile-cash-details-icon {
  display: grid;
  flex: 0 0 28px;
  place-items: center;
  width: 28px;
  height: 28px;
  color: var(--teal);
  font-size: 18px;
  transition: transform 180ms ease;
}

.director-module[open] > .director-module-summary {
  border-bottom: 1px solid var(--line);
  background: var(--surface-soft);
}

.director-module[open] > .director-module-summary .director-module-chevron,
.director-module[open] > .director-module-summary .mobile-cash-details-icon {
  transform: rotate(180deg);
}

.director-module > .director-module-body {
  display: grid;
  gap: 12px;
  padding: 12px;
}

.director-module .director-shift-archive,
.director-module .director-payroll-section {
  margin-top: 0;
  padding-top: 0;
  border-top: 0;
}

body[data-theme="dark"] .director-module-emblem {
  border-color: rgba(91, 210, 190, 0.24);
  background: rgba(15, 124, 99, 0.18);
  color: #89dccd;
}

@media (max-width: 760px) {
  .director-module > .director-module-summary {
    min-height: 54px;
    gap: 8px;
    padding: 9px 10px;
  }

  .director-module-emblem {
    flex-basis: 32px;
    width: 32px;
    height: 32px;
  }

  .director-module-emblem svg {
    width: 17px;
    height: 17px;
  }

  .director-module-copy strong {
    font-size: 13px;
  }

  .director-module > .director-module-body {
    padding: 10px;
  }
}

@media (max-width: 420px) {
  .director-module-copy small {
    display: none;
  }

  .director-module-summary > .pill {
    max-width: 70px;
    overflow: hidden;
    font-size: 9px;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
}

.completed-delete-panel {
  position: relative;
  z-index: 1;
  display: grid;
  gap: 13px;
  width: min(100%, 420px);
  padding: 18px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--surface);
  box-shadow: 0 22px 54px rgba(9, 15, 12, 0.28);
}

.completed-delete-panel label {
  display: grid;
  gap: 6px;
  color: var(--muted);
  font-size: 12px;
  font-weight: 800;
}

.completed-delete-panel input {
  width: 100%;
  min-height: 44px;
  letter-spacing: 0;
  text-align: center;
  font-size: 18px;
  font-weight: 900;
}

.cash-close-panel {
  width: min(100%, 500px);
}

.payment-edit-panel {
  width: min(100%, 540px);
}

.payment-edit-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8px;
}

.payment-edit-total {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 42px;
  padding: 8px 10px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--surface-soft);
  color: var(--muted);
  font-size: 13px;
  font-weight: 900;
  text-align: center;
}

.payment-edit-total.matches {
  border-color: rgba(8, 123, 118, 0.3);
  background: rgba(8, 123, 118, 0.08);
  color: var(--teal-dark);
}

.payment-edit-total.mismatch {
  border-color: rgba(197, 58, 58, 0.25);
  color: var(--red);
}

.cash-close-panel textarea {
  width: 100%;
  min-height: 118px;
  padding: 11px 12px;
  border: 1px solid var(--line);
  border-radius: 8px;
  outline: 0;
  resize: vertical;
  background: var(--surface);
  color: var(--ink);
  font: inherit;
  line-height: 1.45;
}

.cash-close-panel textarea:focus {
  border-color: var(--teal);
  box-shadow: 0 0 0 3px rgba(8, 123, 118, 0.1);
}

.cash-close-actions {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
}

.cash-close-actions .primary-button:disabled {
  border-color: var(--line);
  background: var(--surface-soft);
  color: var(--muted);
  cursor: not-allowed;
  opacity: 0.72;
}

.completed-delete-feedback {
  min-height: 18px;
  margin: 0;
  color: var(--muted);
  font-size: 12px;
  font-weight: 800;
}

.completed-delete-feedback.error {
  color: var(--red);
}

.completed-delete-confirm {
  min-height: 44px;
  border: 1px solid var(--red);
  border-radius: 8px;
  background: var(--red);
  color: #ffffff;
  font-weight: 850;
}

.completed-delete-confirm:hover,
.completed-delete-confirm:focus {
  border-color: #9f2929;
  background: #9f2929;
  color: #ffffff;
}

@media (max-width: 760px) {
  .completed-delete-modal {
    align-items: end;
    padding: 42px 0 0;
  }

  .completed-delete-panel {
    width: 100%;
    padding: 16px 14px calc(16px + env(safe-area-inset-bottom));
    border-right: 0;
    border-bottom: 0;
    border-left: 0;
    border-radius: 8px 8px 0 0;
  }

  .cash-close-actions {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
  }

  .cash-close-actions .primary-button {
    white-space: normal;
  }

  .payment-edit-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .payment-edit-grid input {
    padding-inline: 4px;
    font-size: 14px;
  }
}
