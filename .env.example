# Local server configuration
PORT=3000
HOST=0.0.0.0

# Required for persistent production accounts.
# Render fills this automatically from render.yaml.
DATABASE_URL=postgresql://user:password@host:5432/database

# Required in production. Use at least 8 characters.
ADMIN_INITIAL_PASSWORD=change-this-securely

# Optional local fallback file path.
# ACCOUNT_STORE_FILE=./data/account-store.json
